{
  "name": "LCA",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "$className": "ReplicatedStorage",
      "$ignoreUnknownInstances": true,

      "LCA_Shared": {
        "$path": "src/shared"
      }
    },

    "ServerScriptService": {
      "$className": "ServerScriptService",
      "$ignoreUnknownInstances": true,

      "LCA_Server": {
        "$path": "src/server"
      }
    },

    "StarterGui": {
      "$className": "StarterGui",
      "$ignoreUnknownInstances": true,

      "MainGui": {
        "$className": "ScreenGui",
        "$properties": {
          "ResetOnSpawn": false,
          "IgnoreGuiInset": true,
          "DisplayOrder": 0,
          "ZIndexBehavior": "Sibling",
          "Enabled": true
        },

        "MainGuiClient": {
          "$path": "src/client/MainGuiClient.client.lua"
        },

        "FactoryVisualController": {
          "$path": "src/client/FactoryVisualController.lua"
        },

        "PresentationCoordinator": {
          "$path": "src/client/PresentationCoordinator.lua"
        },

        "PressPresenter": {
          "$path": "src/client/PressPresenter.lua"
        },

        "PresentationPreferences": {
          "$path": "src/client/PresentationPreferences.lua"
        },

        "NotificationPresenter": {
          "$path": "src/client/NotificationPresenter.lua"
        },

        "AudioPresenter": {
          "$path": "src/client/AudioPresenter.lua"
        },

        "CameraPresenter": {
          "$path": "src/client/CameraPresenter.lua"
        },

        "UpgradePresenter": {
          "$path": "src/client/UpgradePresenter.lua"
        },

        "RebirthPresenter": {
          "$path": "src/client/RebirthPresenter.lua"
        },

        "EnergyPropagationPresenter": {
          "$path": "src/client/EnergyPropagationPresenter.lua"
        },

        "WorldAwakeningPresenter": {
          "$path": "src/client/WorldAwakeningPresenter.lua"
        }
      }
    }
  }
}
