{
  "name": "LCA",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "$className": "ReplicatedStorage",
      "$ignoreUnknownInstances": true,

      "LCA_Shared": {
        "$path": "src/shared"
      }
    },

    "ServerScriptService": {
      "$className": "ServerScriptService",
      "$ignoreUnknownInstances": true,

      "LCA_Server": {
        "$path": "src/server"
      }
    },

    "StarterGui": {
      "$className": "StarterGui",
      "$ignoreUnknownInstances": true,

      "MainGui": {
        "$className": "ScreenGui",
        "$properties": {
          "ResetOnSpawn": false,
          "IgnoreGuiInset": true,
          "DisplayOrder": 0,
          "ZIndexBehavior": "Sibling",
          "Enabled": true
        },

        "MainGuiClient": {
          "$path": "src/client/MainGuiClient.client.lua"
        }
      }
    }
  }
}
